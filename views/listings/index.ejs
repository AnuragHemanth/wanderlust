<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>WanderLust</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/png" href="/images/icon.png">
</head>

<body>

  <!-- Include Header -->
  <%- include("../includes/header") %>

  <div class="container mt-4">
    <% if (typeof success !== "undefined" && success.length) { %>
      <p style="color: green; font-weight: bold;"><%= success[0] %></p>
    <% } %>
    <h3 class="mb-4">All Listings</h3>

    <div class="row">
      <% for(let listing of listings) { %>

        <div class="col-12 col-sm-6 col-lg-4 mb-4">
          <div class="card listing-card shadow-sm">

    <img 
  src="<%= listing.image.url || listing.image %>" 
  class="card-img-top"
>

            <div class="card-body">
              <h5 class="card-title"><%= listing.title %></h5>
              <p class="card-text text-muted small">
                <strong>Owner:</strong> 
                <% if (listing.owner) { %>
                  <%= listing.owner.username %>
                <% } else { %>
                  Unknown
                <% } %>
              </p>
              <a href="/listings/<%= listing._id %>" class="btn btn-dark btn-sm">
                View Details
              </a>
            </div>

          </div>
        </div>

      <% } %>
    </div>
  </div>

  <!-- Include Footer -->
  <%- include("../includes/footer") %>

</body>
</html>