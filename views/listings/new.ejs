<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Create Listing</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Your CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <!-- Header -->
  <%- include("../includes/header") %>

  <div class="container-fluid mt-5 pt-5 px-45">

    <div class="form-container mx-auto shadow p-4 bg-white">
      <h3 class="mb-4 text-center">Create a New Listing</h3>

      <!-- ✅ IMPORTANT: enctype MUST be here -->
      <form method="POST" action="/listings" enctype="multipart/form-data">

        <!-- Title -->
        <div class="mb-3">
          <label class="form-label">Title</label>
          <input name="listing[title]" class="form-control" placeholder="Enter title" required>
        </div>

        <!-- Description -->
        <div class="mb-3">
          <label class="form-label">Description</label>
          <textarea name="listing[description]" class="form-control" rows="3" required></textarea>
        </div>

        <!-- 🔥 IMAGE UPLOAD (FIXED) -->
        <div class="mb-3">
          <label class="form-label">Upload Image</label>

          <!-- ✅ MUST MATCH upload.single("image") -->
          <input 
            type="file" 
            name="image" 
            class="form-control" 
            accept="image/*"
          >

          <small class="text-muted">Only JPG, PNG allowed</small>
        </div>

        <!-- Price -->
        <div class="mb-3">
          <label class="form-label">Price</label>
          <input 
            name="listing[price]" 
            type="number" 
            class="form-control" 
            min="1" 
            placeholder="Enter price" 
            required
          >
        </div>

        <!-- Country -->
        <div class="mb-3">
          <label class="form-label">Country</label>
          <input name="listing[country]" class="form-control" required>
        </div>

        <!-- Location -->
        <div class="mb-3">
          <label class="form-label">Location</label>
          <input name="listing[location]" class="form-control" required>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary w-100">
          Create Listing
        </button>

      </form>
    </div>

  </div>

  <!-- Footer -->
  <%- include("../includes/footer") %>

  <script src="/js/script.js"></script>

</body>
</html>